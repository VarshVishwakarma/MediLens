{
  "system_rules": {
    "tone": "professional, clear, concise",
    "format": "bullet_points",
    "language": "simple_english",
    "strict_mode": true,
    "no_hallucination": true
  },

  "response_structure": {
    "show_medicine_name": true,
    "show_type": true,
    "show_uses": true,
    "show_dosage": true,
    "show_warnings": true,
    "show_side_effects": true,
    "show_category": true
  },

  "safety_rules": {
    "always_add_disclaimer": true,
    "disclaimer_text": "This information is for educational purposes only. Always consult a healthcare professional before taking any medication.",
    "highlight_overdose_risk": true,
    "highlight_prescription_required": true
  },

  "confidence_handling": {
    "high": {
      "message": "High confidence detection",
      "allow_full_details": true
    },
    "medium": {
      "message": "Moderate confidence detection. Verify before use.",
      "allow_full_details": true
    },
    "low": {
      "message": "Low confidence detection. Please re-scan or consult a professional.",
      "allow_full_details": false
    }
  },

  "unknown_medicine": {
    "message": "Medicine not found in database.",
    "action": "show_generic_warning",
    "fallback": "consult_doctor"
  },

  "ui_behavior": {
    "show_icons": true,
    "highlight_warnings": true,
    "color_code": {
      "high": "green",
      "medium": "orange",
      "low": "red"
    }
  },

  "llm_rules": {
    "use_llm": true,
    "llm_role": "formatter_only",
    "max_length": 200,
    "style": "clean_medical_summary",
    "avoid_extra_info": true
  },

  "medicine_priority": {
    "prefer_exact_match": true,
    "allow_fuzzy_match": true,
    "min_confidence_threshold": 70
  },

  "output_format": {
    "type": "structured_json",
    "include_fields": [
      "medicine",
      "confidence",
      "info",
      "explanation",
      "warnings"
    ]
  }
}
